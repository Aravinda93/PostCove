{
  "name": "postcove",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "description": "Postcove — a 100% free, open-source, privacy-first local document filing box for German mail. Runs fully client-side, no accounts, no cloud.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "clean": "rm -rf .nuxt .output node_modules package-lock.json pnpm-lock.yaml pnpm-lock.yaml .idea .vscode node-compile-cache .pnpm-store ios android",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt prepare && node scripts/patch-tsconfig.mjs && vue-tsc -b --noEmit",
    "test": "vitest run",
    "og:gen": "node scripts/gen-og.mjs",
    "cap:assets": "capacitor-assets generate --assetPath assets",
    "cap:sync": "nuxt generate && cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:ios": "cap open ios",
    "cap:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "nuxt": "^4.4.7",
    "vue": "^3.5.0",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@iconify-json/lucide": "^1.2.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxt/ui": "^4.0.0",
    "@nuxtjs/i18n": "^10.0.0",
    "@nuxtjs/seo": "^5.1.3",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.0.0"
  },
  "overrides": {
    "vite": "^8.0.16"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.16",
      "sharp": "^0.34.2"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild"
    ]
  }
}
